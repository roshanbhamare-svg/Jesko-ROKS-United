# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Database (SQLite for local dev, swap for PostgreSQL/Supabase URL in prod)
